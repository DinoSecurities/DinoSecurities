# Server port
PORT=3001

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/dinosecurities

# Solana RPC (use Helius for production)
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_RPC_FALLBACK=

# Program IDs (from Anchor deploy)
DINO_CORE_PROGRAM_ID=11111111111111111111111111111111
DINO_HOOK_PROGRAM_ID=11111111111111111111111111111111
DINO_GOV_PROGRAM_ID=11111111111111111111111111111111

# Helius API (for webhooks and enhanced RPCs)
HELIUS_API_KEY=
WEBHOOK_SECRET=your-random-hmac-secret

# KYC Provider (Jumio or Persona)
KYC_PROVIDER_API_KEY=

# Settlement agent keypair (JSON array of bytes or path to keypair file)
SETTLEMENT_AGENT_KEY=

# Arweave / Irys (Solana keypair for uploads)
IRYS_WALLET_KEY=

# IPFS / Pinata
PINATA_API_KEY=
PINATA_SECRET_KEY=

# CORS origin (frontend URL)
CORS_ORIGIN=http://localhost:8080

# Admin wallets (comma-separated base58 addresses)
ADMIN_WALLETS=
